{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "GalaxyNG Server",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/GalaxyNG.Server", "-c", "Release", "--no-launch-profile", "--urls", "http://localhost:5055"],
      "port": 5055
    },
    {
      "name": "GalaxyNG Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173"],
      "cwd": "src/GalaxyNG.Web",
      "port": 5173
    }
  ]
}
